# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram MTProto (my.telegram.org/apps) — 48h limitni olib tashlash uchun
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION=

# PostgreSQL (production: yangi serverdagi DB — eski server/tavba_postgres o‘rniga)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=guardy_db
# Managed Postgres (Neon, Supabase, …) bo'lsa: DB_SSL=true
# DB_SSL=true

# App
NODE_ENV=development
PORT=7777

# Deploy: lokal .env ni serverda /var/www/guardy/.env ga nusxalang (GitHubga commit qilmang).
# Serverda ilova PM2 orqali ishga tushadi; Postgres odatda systemd servisi (docker shart emas).
